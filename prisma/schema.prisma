generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
  engineType    = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  packages  Package[]

  @@map("admins")
}

model Package {
  id                String           @id @default(cuid())
  name              String           @unique
  speed             Int
  price             Float
  durationDays      Int
  description       String           @default("")
  isActive          Boolean          @default(true)
  createdBy         String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  purchasePrice     Float?
  serviceProviderId String?
  clients           Client[]
  creator           Admin            @relation(fields: [createdBy], references: [id])
  serviceProvider   ServiceProvider? @relation(fields: [serviceProviderId], references: [id])

  @@map("packages")
}

model ServiceProvider {
  id          String    @id @default(cuid())
  name        String    @unique
  contactInfo String?
  address     String?
  email       String?
  phone       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  packages    Package[]

  @@map("service_providers")
}

model Client {
  id            String        @id @default(cuid())
  name          String
  phone         String
  email         String?
  cnic          String
  city          String
  area          String
  country       String
  packageId     String
  price         Float
  startDate     DateTime
  expiryDate    DateTime
  paymentStatus PaymentStatus
  status        ClientStatus
  notes         String?
  createdAt     DateTime      @default(now())
  package       Package       @relation(fields: [packageId], references: [id])
  payments      Payment[]

  @@map("clients")
}

enum PaymentStatus {
  paid
  unpaid
  partial
}

enum ClientStatus {
  active
  expired
  suspended
}

model Payment {
  id          String   @id @default(cuid())
  clientId    String
  amount      Float
  paymentDate DateTime @default(now())
  method      String?  // e.g., cash, bank transfer, online
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  client Client @relation(fields: [clientId], references: [id])

  @@map("payments")
}

model Expense {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  category    String   // e.g., electricity, rent, equipment
  date        DateTime @default(now())
  description String?
  receipt     String?  // path to receipt image/file
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("expenses")
}
