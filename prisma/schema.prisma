generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                    String                 @id @default(cuid())
  name                  String
  isActive              Boolean                @default(true)
  modulesEnabled        Json                   @default("{\"billing\":true,\"inventory\":false,\"employees\":true}")
  createdAt             DateTime               @default(now())
  ledgers               AccountLedger[]
  AccountTransaction    AccountTransaction[]
  admins                Admin[]
  areas                 Area[]
  audits                AuditLog[]
  clients               Client[]
  complaints            Complaint[]
  employeeActivities    EmployeeActivity[]
  employees             Employee[]
  expenses              Expense[]
  inventoryItems        InventoryItem[]
  inventoryTransactions InventoryTransaction[]
  invoices              Invoice[]              // Add invoices relation
  packages              Package[]
  payments              Payment[]
  providers             ServiceProvider[]
  productSales          ProductSale[]
  subscription          Subscription?
  saasInvoices          SaaSInvoice[]  // SaaS-specific invoices (isolated from client invoices)

  @@map("companies")
}

model Admin {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  createdAt     DateTime       @default(now())
  role          Role           @default(EMPLOYEE)
  updatedAt     DateTime       @updatedAt
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id])
  audits        AuditLog[]
  clients       Client[]
  packages      Package[]
  refreshTokens RefreshToken[]
  sessions      Session[]

  @@map("admins")
  @@index([companyId])
  @@index([role])
  @@index([companyId, role])
}

model ServiceProvider {
  id          String    @id @default(cuid())
  name        String    @unique
  contactInfo String?
  address     String?
  email       String?
  phone       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  companyId   String
  packages    Package[]
  company     Company   @relation(fields: [companyId], references: [id])

  @@map("service_providers")
}

model Package {
  id                String           @id @default(cuid())
  name              String           @unique
  speed             Int
  price             Float
  durationDays      Int
  description       String           @default("")
  isActive          Boolean          @default(true)
  createdBy         String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  purchasePrice     Float?
  serviceProviderId String?
  companyId         String
  clients           Client[]
  company           Company          @relation(fields: [companyId], references: [id])
  creator           Admin            @relation(fields: [createdBy], references: [id])
  serviceProvider   ServiceProvider? @relation(fields: [serviceProviderId], references: [id])

  @@map("packages")
  @@index([companyId])
  @@index([isActive])
  @@index([companyId, isActive])
}

model Area {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  clients     Client[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("areas")
}

model Client {
  id            String        @id @default(cuid())
  name          String
  username      String?       @unique
  phone         String        @unique
  cnic          String        @unique
  city          String
  areaName      String?
  country       String
  packageId     String
  price         Float
  startDate     DateTime
  expiryDate    DateTime
  paymentStatus PaymentStatus
  status        ClientStatus
  notes         String?
  createdAt     DateTime      @default(now())
  email         String?       @unique
  createdBy     String
  companyId     String
  areaId        String?
  area          Area?         @relation(fields: [areaId], references: [id])
  company       Company       @relation(fields: [companyId], references: [id])
  creator       Admin         @relation(fields: [createdBy], references: [id])
  package       Package       @relation(fields: [packageId], references: [id])
  complaints    Complaint[]
  payments      Payment[]
  invoices      Invoice[]
  productSales  ProductSale[]

  @@map("clients")
  @@index([companyId])
  @@index([status])
  @@index([paymentStatus])
  @@index([expiryDate])
  @@index([companyId, status])
  @@index([companyId, paymentStatus])
  @@index([companyId, expiryDate])
  @@index([companyId, status, expiryDate])
  @@index([username])
  @@index([areaId])
}

model Invoice {
  id                String      @id @default(cuid())
  clientId          String
  amount            Float       // DEPRECATED: Use totalAmount for new invoices; kept for backward compatibility
  totalAmount       Float?      // New field: sum of all line items (null for legacy invoices - computed from amount)
  issuedDate        DateTime    @default(now())
  dueDate           DateTime
  status            InvoiceStatus @default(unpaid)
  description       String?
  billingMonth      String?     // Format: "2026-04" (YYYY-MM)
  source            InvoiceSource @default(manual)  // Track invoice origin: package, product_sale, or manual
  carryForwardAmount Float      @default(0)  // Amount carried from previous invoice
  creditUsed        Float       @default(0)  // Credits/overpayments applied
  additionalCharges Json?       // { items: [{name: "Router", amount: 1000}, {name: "Cable", amount: 10000}] }
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  companyId         String

  // Invoice chaining relations
  previousInvoiceId String?
  previousInvoice   Invoice?    @relation("InvoiceChain", fields: [previousInvoiceId], references: [id])
  nextInvoices      Invoice[]   @relation("InvoiceChain")

  client            Client      @relation(fields: [clientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  company           Company     @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payments          Payment[]
  items             InvoiceItem[]

  @@map("invoices")
  @@index([clientId])
  @@index([companyId])
  @@index([issuedDate])
  @@index([dueDate])
  @@index([clientId, issuedDate])
  @@index([companyId, issuedDate])
  @@index([clientId, billingMonth])
  @@index([companyId, billingMonth])
  @@index([previousInvoiceId])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  name        String
  description String?
  amount      Float
  quantity    Int      @default(1)
  createdAt   DateTime @default(now())

  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
  @@index([invoiceId])
}

model Payment {
  id            String   @id @default(cuid())
  clientId      String   // Required - all payments must be linked to a client
  invoiceId     String   // Required - all payments must be linked to an invoice
  amount        Float
  paymentDate   DateTime @default(now())
  method        String?  // Legacy field, use gateway
  notes         String?
  gateway       String?  // stripe, jazzcash, easypaisa
  transactionId String?  // Gateway transaction ID
  status        String   @default("pending") // pending, success, failed, refunded
  referenceType String?  // subscription, invoice
  referenceId   String?  // subscriptionId or invoiceId
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  companyId     String
  client        Client   @relation(fields: [clientId], references: [id])
  invoice       Invoice  @relation(fields: [invoiceId], references: [id])
  company       Company  @relation(fields: [companyId], references: [id])

  @@map("payments")
  @@index([clientId])
  @@index([invoiceId])
  @@index([companyId])
  @@index([paymentDate])
  @@index([clientId, paymentDate])
  @@index([companyId, paymentDate])
  @@index([gateway])
  @@index([status])
  @@index([transactionId])
}

model Expense {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  category    String
  date        DateTime @default(now())
  description String?
  receipt     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])

  @@map("expenses")
  @@index([companyId])
  @@index([date])
  @@index([companyId, date])
}

model Complaint {
  id          String          @id @default(cuid())
  clientId    String
  title       String
  description String
  status      ComplaintStatus @default(open)
  priority    String          @default("medium")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  assignedToId String?
  companyId   String
  client      Client          @relation(fields: [clientId], references: [id])
  company     Company         @relation(fields: [companyId], references: [id])
  assignedTo  Employee?       @relation("ComplaintAssignee", fields: [assignedToId], references: [id])

  @@map("complaints")
  @@index([companyId])
  @@index([status])
  @@index([companyId, status])
  @@index([assignedToId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  companyId String
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id])
  user      Admin    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model AccountLedger {
  id           String               @id @default(cuid())
  name         String               @unique
  balance      Float                @default(0)
  description  String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  type         AccountType
  companyId    String
  company      Company              @relation(fields: [companyId], references: [id])
  transactions AccountTransaction[]

  @@unique([companyId, name])
  @@map("account_ledgers")
}

model AccountTransaction {
  id              String          @id @default(cuid())
  accountId       String
  amount          Float
  description     String
  reference       String?
  referenceType   String?         // Payment, Invoice, Expense, Refund
  date            DateTime        @default(now())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  transactionType TransactionKind
  companyId       String
  account         AccountLedger   @relation(fields: [accountId], references: [id])
  company         Company         @relation(fields: [companyId], references: [id])

  @@map("account_transactions")
  @@index([companyId])
  @@index([referenceType])
  @@index([date])
  @@index([companyId, date])
}

model InventoryItem {
  id           String                 @id @default(cuid())
  name         String
  category     String
  quantity     Float                  @default(0)
  unit         String                 @default("piece")  // meter, feet, roll, piece, kg, etc.
  unitPrice    Float
  totalValue   Float                  @default(0)
  companyId    String
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  company      Company                @relation(fields: [companyId], references: [id])
  transactions InventoryTransaction[]

  @@map("inventory_items")
}

model InventoryTransaction {
  id        String        @id @default(cuid())
  itemId    String
  type      String
  quantity  Float
  note      String?
  companyId String
  createdAt DateTime      @default(now())
  company   Company       @relation(fields: [companyId], references: [id])
  item      InventoryItem @relation(fields: [itemId], references: [id])

  @@map("inventory_transactions")
}

model Employee {
  id          String             @id @default(cuid())
  name        String
  email       String             @unique
  phone       String?
  role        String
  salary      Float?
  companyId   String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  permissions Json?
  activities  EmployeeActivity[]
  complaints  Complaint[]        @relation("ComplaintAssignee")
  company     Company            @relation(fields: [companyId], references: [id])

  @@map("employees")
}

model EmployeeActivity {
  id         String   @id @default(cuid())
  employeeId String
  action     String
  metadata   Json?
  companyId  String
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id])
  employee   Employee @relation(fields: [employeeId], references: [id])

  @@map("employee_activities")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)
  userAgent String?
  ip        String?
  user      Admin    @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  lastActive DateTime @default(now())
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  userAgent  String?
  ipAddress  String?
  isActive   Boolean  @default(true)
  user       Admin    @relation(fields: [userId], references: [id])

  @@map("sessions")
}

enum Role {
  EMPLOYEE
  ADMIN
  SUPER_ADMIN
}

model Plan {
  id          String   @id @default(cuid())
  name        String   @unique
  price       Float
  duration    Int      // Duration in days
  description String?
  features    Json     // { billing: true, inventory: true, employees: true, maxClients: 100 }
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  subscriptions Subscription[]
  saasInvoices SaaSInvoice[]  // SaaS invoices for this plan

  @@map("plans")
}

model Subscription {
  id          String   @id @default(cuid())
  companyId   String   @unique
  planId      String
  startDate   DateTime
  endDate     DateTime
  status      String   @default("active") // active, expired, cancelled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan        Plan     @relation(fields: [planId], references: [id])

  @@index([companyId])
  @@index([planId])
  @@index([status])
  @@index([endDate])
  @@map("subscriptions")
}

// SaaS-specific Invoice (isolated from client invoices)
model SaaSInvoice {
  id                String          @id @default(cuid())
  companyId         String
  amount            Float
  issuedDate        DateTime        @default(now())
  dueDate           DateTime
  status            SaaSInvoiceStatus @default(unpaid)
  description       String?
  billingPeriod     String?         // Format: "2026-Q1" or "2026-04" (YYYY-MM)
  carryForwardAmount Float          @default(0)
  creditUsed        Float           @default(0)
  additionalCharges Json?           // { items: [{name: "Extra Users", amount: 5000}, {name: "Storage", amount: 2000}] }
  planId            String?         // The plan this invoice is for
  plan              Plan?           @relation(fields: [planId], references: [id])
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Invoice chaining relations
  previousInvoiceId String?
  previousInvoice   SaaSInvoice?    @relation("SaaSInvoiceChain", fields: [previousInvoiceId], references: [id])
  nextInvoices      SaaSInvoice[]   @relation("SaaSInvoiceChain")

  company           Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payments          SaaSPayment[]

  @@map("saas_invoices")
  @@index([companyId])
  @@index([issuedDate])
  @@index([dueDate])
  @@index([companyId, issuedDate])
  @@index([companyId, billingPeriod])
  @@index([previousInvoiceId])
  @@index([planId])
}

// SaaS-specific Payment (isolated from client payments)
model SaaSPayment {
  id            String          @id @default(cuid())
  invoiceId     String
  amount        Float
  paymentDate   DateTime        @default(now())
  method        String?         // bank_transfer, credit_card, jazzcash, easypaisa
  notes         String?
  gateway       String?         // stripe, jazzcash, easypaisa
  transactionId String?
  status        String          @default("pending") // pending, success, failed, refunded
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  invoice       SaaSInvoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("saas_payments")
  @@index([invoiceId])
  @@index([paymentDate])
  @@index([gateway])
  @@index([status])
  @@index([transactionId])
}

enum SaaSInvoiceStatus {
  unpaid
  partial
  paid
  overdue
  cancelled
}

model ProductSale {
  id                 String   @id @default(cuid())
  clientId           String?
  productName        String
  actualPrice        Float
  sellingPrice       Float
  quantity           Int      @default(1)
  unitProfit         Float
  totalOtherIncome   Float
  status             ProductSaleStatus @default(unpaid)
  notes              String?
  saleDate           DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  companyId          String
  client             Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([saleDate])
  @@index([companyId, saleDate])
  @@index([clientId])
  @@map("product_sales")
}

enum ProductSaleStatus {
  unpaid
  paid
}

enum InvoiceStatus {
  unpaid
  partial
  paid
}

enum InvoiceSource {
  package       // Monthly subscription package
  product_sale  // Auto-generated from product sale
  manual        // Manually created invoice
}

enum PaymentStatus {
  paid
  unpaid
  partial
}

enum ClientStatus {
  active
  expired
  suspended
}

enum ComplaintStatus {
  open
  in_progress
  resolved
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum TransactionKind {
  DEBIT
  CREDIT
  PAYMENT
  REFUND
  ADJUSTMENT
  FEE
}
